				</ul>
			</div>

			<div class="block tenant-only-qris" style="display: none">
				<div class="list strong inset dividers-ios">
					<ul>
						<li class="item-content item-input">
							<div class="item-inner">
								<div class="item-title item-floating-label">
									Nama Merchant (opsional)
								</div>
								<div class="item-input-wrap">
									<input id="qrisName" type="text" />
								</div>
							</div>
						</li>

						<li class="item-content">
							<div class="item-inner">
								<div class="item-title">QRIS</div>
								<div class="item-after">
									<a
										href="#"
										class="button button-small button-fill upload-qris-btn"
										>Upload</a
									>
								</div>
							</div>
						</li>

						<li class="item-content qris-preview-row" style="display: none">
							<div class="item-inner">
								<div class="item-title">Preview</div>
								<div class="item-after">
									<img
										class="qris-preview"
										src=""
										style="height: 48px; border-radius: 8px"
									/>
									<a
										href="#"
										class="link text-color-red remove-qris-btn"
										style="margin-left: 10px"
									>
										Hapus
									</a>
								</div>
							</div>
						</li>

						<li class="item-content">
							<div class="item-inner">
