<script>
    import { getToken } from "./../js/auth.js";

    export default (props, { $h, $on, $update, $f7 }) => {
        const API_BASE = "http://localhost:8000/api";
        
        let activeFilter = "all";
        let searchQuery = "";
        let selectedOrder = null;
        let orders = [];
        let loading = false;

        const rupiah = (n) => "Rp " + Number(n || 0).toLocaleString("id-ID");

        function getOrderTypeMeta(type) {
            if (type === "take_away") {
                return {
                    type: "take_away",
                    label: "Take Away",
                    desc: "Pesanan dibungkus untuk dibawa",
                    icon: "bag_fill",
                    className: "take-away",
                    actionText: "TANDAI SIAP DIAMBIL",
                };
            }

            return {
                type: "dine_in",
                label: "Dine In",
                desc: "Makan di tempat",
                icon: "fork_knife",
                className: "dine-in",
                actionText: "TANDAI SIAP DISAJIKAN",
            };
        }


        function shortTime(dt) {
            try {
                const d = new Date(dt);
                return d.toLocaleString("id-ID", { day: "2-digit", month: "short", hour: "2-digit", minute: "2-digit" });
            } catch { return "-"; }
        }

        const getItemsDetailed = () => {
            if (!selectedOrder || !selectedOrder.raw || !selectedOrder.raw.items) return [];
            return selectedOrder.raw.items;
        };

        const hasOptions = (item) => {
            return item.options && (Array.isArray(item.options) ? item.options.length > 0 : Object.keys(item.options).length > 0);
        };

        const renderOptionValue = (val) => {
            // Jika val adalah objek (misal: {label: 'Keju', price: 5000})
            if (typeof val === 'object' && val !== null) {
                return val.label || val.value || JSON.stringify(val);
            }
            // Jika val adalah string biasa
            return val;
        };

        function buildDesc(items) {
            if (!Array.isArray(items) || !items.length) return "-";
            return items.map((it) => `${it.menu_name} (${it.qty})`).join(", ");
        }

        function itemsCount(items) {
            if (!Array.isArray(items)) return 0;
            return items.reduce((sum, it) => sum + Number(it.qty || 0), 0);
        }

        // FUNGSI BARU: Hitung selisih waktu secara real-time
        function getTimeRemaining(targetDate, status) {
            // JIKA status sudah selesai atau batal, jangan tampilkan timer
            if (status === 'done' || status === 'cancelled') {
                return "Selesai"; 
            }

            if (!targetDate) return "Belum diatur";
            
            const total = Date.parse(targetDate) - Date.now();
            
            // JIKA waktu habis tapi status masih 'process'
            if (total <= 0) return "Siap Disajikan!";

            const seconds = Math.floor((total / 1000) % 60);
            const minutes = Math.floor((total / 1000 / 60) % 60);
            const hours = Math.floor((total / (1000 * 60 * 60)) % 24);

            return [
                hours.toString().padStart(2, '0'),
                minutes.toString().padStart(2, '0'),
                seconds.toString().padStart(2, '0')
            ].join(':');
        }

        function normalizeOrder(o) {
            const orderType = getOrderTypeMeta(o.order_type);

            return {
                id: o.id,
                time: shortTime(o.created_at),
                targetTime: o.estimation_time,
                estimation: getTimeRemaining(o.estimation_time, o.status),
                items: itemsCount(o.items),
                desc: buildDesc(o.items),
                price: rupiah(o.grand_total),
                customer: o.user?.name || "User",
                status: o.status,
                payment_status: o.payment_status,

                // Tambahan untuk Dine In / Take Away
                orderType: orderType.type,
                orderTypeLabel: orderType.label,
                orderTypeDesc: orderType.desc,
                orderTypeIcon: orderType.icon,
                orderTypeClass: orderType.className,
                orderActionText: orderType.actionText,

                raw: o,
            };
        }

        async function loadOrders() {
            try {
                loading = true; $update();
                const token = getToken();
                const res = await fetch(`${API_BASE}/tenant/orders`, {
                    headers: { Authorization: `Bearer ${token}` }
                });
                const data = await res.json();
                orders = data.map(normalizeOrder);
            } catch (err) { console.error(err); }
            finally { loading = false; $update(); }
        }

        function getFilteredOrders() {
            let filtered = orders;
            if (activeFilter !== "all") filtered = orders.filter(o => o.status === activeFilter);
            if (searchQuery) {
                filtered = filtered.filter(o => o.customer.toLowerCase().includes(searchQuery.toLowerCase()) || o.id.toString().includes(searchQuery));
            }
            return filtered;
        }

        function replaceOrder(newRaw) {
            const idx = orders.findIndex(o => o.id === newRaw.id);
            if (idx !== -1) {
                orders[idx] = normalizeOrder(newRaw);
                $update();
            }
        }

        async function approveAndProcess() {
            $f7.dialog.prompt("Berapa menit estimasi penyajian?", "Estimasi Waktu", async (minutes) => {
                if (!minutes || isNaN(minutes)) {
                    $f7.dialog.alert("Harap masukkan angka menit yang valid.");
                    return;
                }
                try {
                    $f7.dialog.preloader("Memproses...");
                    const token = getToken();

                    // 1. Approve Payment (Jika ada)
                    await fetch(`${API_BASE}/tenant/payments/${selectedOrder.id}/approve`, {
                        method: "PATCH",
                        headers: { Authorization: `Bearer ${token}` }
                    });

                    // 2. Update Status & Estimasi
                    const res = await fetch(`${API_BASE}/tenant/orders/${selectedOrder.id}/status`, {
                        method: "PATCH",
                        headers: { "Content-Type": "application/json", Authorization: `Bearer ${token}` },
                        body: JSON.stringify({ status: "process", estimation_time: minutes })
                    });

                    const result = await res.json();
                    
                    // Gunakan data order yang dikembalikan backend
                    replaceOrder(result.order || result);

                    $f7.dialog.close();
                    $f7.sheet.close(".my-sheet");
                    $f7.toast.create({ text: "Pesanan diproses!", closeTimeout: 2000 }).open();
                } catch (err) {
                    $f7.dialog.close();
                    $f7.dialog.alert("Gagal: " + err.message);
                }
            });
        }

        async function updateStatus(newStatus) {
            try {
                $f7.dialog.preloader("Updating...");
                const token = getToken();
                const res = await fetch(`${API_BASE}/tenant/orders/${selectedOrder.id}/status`, {
                    method: "PATCH",
                    headers: { "Content-Type": "application/json", Authorization: `Bearer ${token}` },
                    body: JSON.stringify({ status: newStatus })
                });
                const data = await res.json();
                replaceOrder(data.order || data);
                $f7.dialog.close();
                $f7.sheet.close(".my-sheet");
            } catch (err) {
                $f7.dialog.close();
                $f7.dialog.alert("Gagal update status");
            }
        }

        const openActionSheet = (order) => {
            selectedOrder = order;
            $update();
            $f7.sheet.open(".my-sheet");
        };

        const setFilter = (f) => { activeFilter = f; $update(); };
        const getItemsWithNotes = () => selectedOrder?.raw?.items?.filter(it => it.notes) || [];
        const newCount = () => orders.filter(o => o.status === 'new').length;

        $on("pageInit", () => {
            loadOrders();

            // LOGIKA COUNTDOWN REAL-TIME (Sinkron dengan Waktu HP)
            setInterval(() => {
                let needUpdate = false;
                orders = orders.map(o => {
                    if (o.status === 'process' && o.targetTime) {
                        const newEst = getTimeRemaining(o.targetTime);
                        if (o.estimation !== newEst) {
                            o.estimation = newEst;
                            needUpdate = true;
                        }
                    }
                    return o;
                });

                if (needUpdate) $update();
            }, 1000); 
        });

        return $render;
    };
</script>
