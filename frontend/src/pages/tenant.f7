<template>
	<div class="page" data-name="tenant" style="background-color: #f5f7fa">
		<div class="navbar navbar-large navbar-transparent">
			<div class="navbar-bg" style="background-color: #fff"></div>
			<div class="navbar-inner">
				<div class="left">
					<div
						style="
							padding-left: 16px;
							display: flex;
							align-items: center;
							gap: 8px;
						"
					>
						<div class="icon-container-small">
							<i class="icon f7-icons text-color-blue" style="font-size: 20px"
								>building_2_fill</i
							>
						</div>
						<div>
							<div style="font-size: 10px; color: #8e8e93; font-weight: 500">
								Lokasi Saat Ini
							</div>
							<div style="font-size: 14px; font-weight: 700; color: #1a1a1a">
								Kantin LPKIA
							</div>
						</div>
					</div>
				</div>
				<div class="right">
					<a class="link icon-only">
						<i class="icon f7-icons text-color-black">bell</i>
						<span
							class="badge color-red"
							style="
								position: absolute;
								top: 8px;
								right: 8px;
								transform: scale(0.7);
							"
						>
							${newCount()}
						</span>
					</a>
					<a class="link icon-only" href="/profile">
						<i class="icon f7-icons text-color-black">person_circle</i>
					</a>
				</div>
			</div>
		</div>

		<div class="toolbar tabbar toolbar-bottom">
			<div class="toolbar-inner">
				<a class="tab-link tab-link-active" data-index="0">
					<i class="icon f7-icons">house_fill</i>
					<span class="tabbar-label">Beranda</span>
				</a>
				<a class="tab-link" data-index="1" href="/tenant/menus">
					<i class="icon f7-icons">square_list_fill</i>
					<span class="tabbar-label">Menu</span>
				</a>
				<a class="tab-link" data-index="2" href="/tenant/riwayat">
					<i class="icon f7-icons">timer_fill</i>
					<span class="tabbar-label">Riwayat</span>
				</a>
				<a class="tab-link" href="/profile" data-index="3">
					<i class="icon f7-icons">person_circle_fill</i>
					<span class="tabbar-label">Profil</span>
				</a>
			</div>
		</div>
		<div class="page-content" style="padding-top: 70px; padding-bottom: 90px">
			<div class="block" style="margin: 16px 0">
				<form class="searchbar">
					<div class="searchbar-inner">
						<div class="searchbar-input-wrap">
							<input type="search" placeholder="Cari pesanan..." />
							<i class="searchbar-icon"></i>
							<span class="input-clear-button"></span>
						</div>
						<span class="searchbar-disable-button"></span>
					</div>
				</form>
			</div>

			<div class="block" style="margin: 0 0 24px 0">
				<div
					class="display-flex justify-content-space-between text-align-center"
					style="padding: 0 8px"
				>
					<div class="category-item" @click="${() => setFilter('all')}">
						<div
							class="category-icon ${activeFilter === 'all' ? 'active-blue' : 'bg-gray'}"
						>
							<i
								class="icon f7-icons ${activeFilter === 'all' ? 'text-color-white' : 'text-color-gray'}"
								>square_list_fill</i
							>
						</div>
						<span
							class="category-label ${activeFilter === 'all' ? 'text-color-black font-weight-bold' : ''}"
							>Semua</span
						>
					</div>

					<div class="category-item" @click="${() => setFilter('new')}">
						<div
							class="category-icon ${activeFilter === 'new' ? 'active-blue' : 'bg-gray'}"
						>
							<i
								class="icon f7-icons ${activeFilter === 'new' ? 'text-color-white' : 'text-color-gray'}"
								>bell_fill</i
							>
						</div>
						<span
							class="category-label ${activeFilter === 'new' ? 'text-color-black font-weight-bold' : ''}"
						>
							Baru
						</span>
					</div>

					<div class="category-item" @click="${() => setFilter('process')}">
						<div
							class="category-icon ${activeFilter === 'process' ? 'active-blue' : 'bg-gray'}"
						>
							<i
								class="icon f7-icons ${activeFilter === 'process' ? 'text-color-white' : 'text-color-gray'}"
								>flame_fill</i
							>
						</div>
						<span
							class="category-label ${activeFilter === 'process' ? 'text-color-black font-weight-bold' : ''}"
							>Proses</span
						>
					</div>

					<div class="category-item" @click="${() => setFilter('done')}">
						<div
							class="category-icon ${activeFilter === 'done' ? 'active-blue' : 'bg-gray'}"
						>
							<i
								class="icon f7-icons ${activeFilter === 'done' ? 'text-color-white' : 'text-color-gray'}"
								>checkmark_circle_fill</i
							>
						</div>
						<span
							class="category-label ${activeFilter === 'done' ? 'text-color-black font-weight-bold' : ''}"
							>Selesai</span
						>
					</div>
				</div>
			</div>

			<div
				class="block-title"
				style="margin-left: 20px; font-weight: 700; color: #333"
			>
				${activeFilter === 'all' ? 'Semua Pesanan' : activeFilter === 'new' ?
				'Pesanan Baru Masuk' : activeFilter === 'process' ? 'Sedang Diproses' :
				'Riwayat Selesai'}
			</div>

			<div class="list no-hairlines-md" style="margin-top: 0; padding: 0 16px">
				${getFilteredOrders().length === 0 ? $h`
				<div
					class="block text-align-center"
					style="margin-top: 30px; opacity: 0.5"
				>
					<i class="icon f7-icons" style="font-size: 48px; color: #ccc"
						>square_list</i
					>
					<p>Tidak ada pesanan</p>
				</div>
				` : $h` ${getFilteredOrders().map((order) => $h`
				<div class="card-replica" @click="${() => openActionSheet(order)}">
					<div class="card-top">
						<div class="order-id">#${order.id}</div>
						<div class="order-time">${order.time}</div>
					</div>

					<div class="card-body">
						<div class="food-thumb">
							<i class="icon f7-icons text-color-white">bag_fill</i>
						</div>

						<div class="food-details">
							<div class="food-title">${order.items} Item Pesanan</div>
							<div class="food-subtitle">${order.desc}</div>
							<div class="rating-pill">
								<i class="icon f7-icons size-12 text-color-white"
									>person_fill</i
								>
								<span>${order.customer}</span>
							</div>
						</div>
					</div>

					<div class="card-footer-custom">
						<div class="price">Rp ${order.price}</div>

						${order.status === 'new' ? $h`
						<div class="status-mini bg-red">Perlu Konfirmasi</div>
						` : order.status === 'process' ? $h`
						<div class="status-mini bg-orange">Sedang Dimasak</div>
						` : $h`
						<div class="status-mini bg-green">Selesai</div>
						`}
					</div>
				</div>
				`)} `}
			</div>
		</div>

		<div
			class="sheet-modal my-sheet"
			style="border-radius: 16px 16px 0 0; height: auto"
		>
			<div class="sheet-modal-inner">
				<div
					class="block-title text-align-center"
					style="font-size: 18px; margin-top: 24px"
				>
					Update Status Pesanan
				</div>
				<div class="block">
					${selectedOrder ? $h`
					<div class="text-align-center" style="margin-bottom: 20px">
						<div style="font-size: 24px; font-weight: 800; color: #2196f3">
							#${selectedOrder.id}
						</div>
						<div style="color: #666">${selectedOrder.desc}</div>
					</div>

					<div class="popup popup-proof">
						<div class="page">
							<div class="navbar">
								<div class="navbar-inner">
									<div class="left"><a class="link popup-close">Tutup</a></div>
									<div class="title">Bukti Pembayaran</div>
								</div>
							</div>

							<div class="page-content" style="padding: 16px; background: #fff">
								<img
									id="proofImg"
									style="width: 100%; border-radius: 18px; display: block"
								/>
								<div style="height: 14px"></div>
								<div
									class="text-align-center"
									style="color: #8e8e93; font-size: 12px"
								>
									Pastikan nama & nominal sesuai sebelum approve.
								</div>
							</div>
						</div>
					</div>

					<div class="sheet-actions">
						<a class="button button-large button-fill color-gray sheet-close">
							Tutup
						</a>

						${selectedOrder.payment_status === 'waiting_confirmation' ? $h`
						<div class="sheet-actions-right">
							${selectedOrder.payment_method === 'qris' &&
							selectedOrder.payment_proof ? $h`
							<a
								class="button button-large button-outline btn-proof"
								@click="${openProof}"
							>
								Lihat Bukti
							</a>
							` : $h``}

							<a
								class="button button-large button-fill color-blue sheet-close"
								@click="${approveAndProcess}"
							>
								Approve
							</a>

							<a
								class="button button-large button-outline color-red"
								@click="${rejectPayment}"
							>
								Tolak
							</a>
						</div>
						` : selectedOrder.status === 'process' ? $h`
						<a
							class="button button-large button-fill color-green sheet-close"
							@click="${() => updateStatus('done')}"
						>
							Tandai Selesai
						</a>
						` : selectedOrder.status === 'done' ? $h`
						<a class="button button-large button-outline color-gray" disabled>
							Sudah Selesai
						</a>
						` : $h`
						<a class="button button-large button-outline color-gray" disabled>
							Menunggu Pembayaran
						</a>
						`}
					</div>

					` : $h`
					<div></div>
					`}
				</div>
			</div>
		</div>
	</div>
</template>

<style>
	/* CSS Tambahan untuk Update Ini */
	.status-mini {
		font-size: 11px;
		font-weight: 600;
		padding: 4px 8px;
		border-radius: 4px;
		color: white;
	}
	.bg-red {
		background: #ff3b30;
	}
	.bg-orange {
		background: #ff9500;
	}
	.bg-green {
		background: #4cd964;
	}

	/* CSS Lama */
	.icon-container-small {
		width: 32px;
		height: 32px;
		background: #e3f2fd;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.search-replica {
		background: #e6e9ef;
		border-radius: 12px;
		padding: 12px 16px;
		display: flex;
		align-items: center;
	}
