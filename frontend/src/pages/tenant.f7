	}
	.btn-proof {
		border-color: rgba(33, 150, 243, 0.35) !important;
		color: #2196f3 !important;
	}
</style>

<script>
	import { getToken } from "./../js/auth.js";

	export default (props, { $h, $on, $update, $f7 }) => {
		const API_BASE = "http://localhost:8000/api";
		const STORAGE_BASE = "http://localhost:8000/storage/";

		let activeFilter = "all";
		let searchQuery = "";
		let selectedOrder = null;

		// data dari backend
		let orders = [];
		let loading = false;

		const rupiah = (n) => "Rp " + Number(n || 0).toLocaleString("id-ID");

		function shortTime(dt) {
			try {
				const d = new Date(dt);
				return d.toLocaleString("id-ID", {
					day: "2-digit",
					month: "short",
					hour: "2-digit",
					minute: "2-digit",
				});
			} catch {
				return "-";
			}
		}

		function buildDesc(items) {
			if (!Array.isArray(items) || !items.length) return "-";
			return items.map((it) => `${it.menu_name} (${it.qty})`).join(", ");
		}

		function itemsCount(items) {
			if (!Array.isArray(items)) return 0;
			return items.reduce((sum, it) => sum + Number(it.qty || 0), 0);
		}

		function normalizeOrder(o) {
			return {
				id: o.id,
				time: shortTime(o.created_at),
				items: itemsCount(o.items),
				desc: buildDesc(o.items),
				price: rupiah(o.grand_total),
				customer: o.user?.name || "User",
				status: o.status, // new / process / done / cancelled
				payment_status: o.payment_status || "unpaid",
				payment_method: o.payment_method || null,
				payment_proof: o.payment_proof || null,
				raw: o,
			};
		}

		async function fetchTenantOrders() {
			const token = getToken();
			if (!token) throw new Error("Silakan login dulu");

			const res = await fetch(`${API_BASE}/tenant/orders`, {
				headers: {
					Accept: "application/json",
					Authorization: `Bearer ${token}`,
				},
			});

			const data = await res.json().catch(() => []);
			if (!res.ok)
				throw new Error(data?.message || "Gagal mengambil pesanan tenant");
			return Array.isArray(data) ? data : [];
		}

		async function loadOrders() {
			try {
				loading = true;
				$update();

				const data = await fetchTenantOrders();
				orders = data.map(normalizeOrder);
			} finally {
				loading = false;
				$update();
			}
		}

		// filter + search
		function getFilteredOrders() {
			let list = orders;

			if (activeFilter !== "all") {
				list = list.filter((o) => o.status === activeFilter);
			}

			if (searchQuery.trim()) {
				const q = searchQuery.toLowerCase();
				list = list.filter((o) => {
					const hay = `${o.id} ${o.customer} ${o.desc}`.toLowerCase();
					return hay.includes(q);
				});
			}

			return list;
		}

		const setFilter = (filterName) => {
			activeFilter = filterName;
			$update();
		};

		const openActionSheet = (order) => {
			selectedOrder = order;
			$update();
			$f7.sheet.open(".my-sheet");
		};

		// ===== ACTIONS TO BACKEND =====
		async function patchTenantPayment(orderId, action) {
			const token = getToken();
			const res = await fetch(`${API_BASE}/tenant/orders/${orderId}/payment`, {
				method: "PATCH",
				headers: {
					Accept: "application/json",
					"Content-Type": "application/json",
					Authorization: `Bearer ${token}`,
				},
				body: JSON.stringify({ action }), // approve / reject
			});

			const data = await res.json().catch(() => ({}));
			if (!res.ok)
				throw new Error(data?.message || "Gagal verifikasi pembayaran");
			return data;
		}

		async function patchTenantStatus(orderId, status) {
			const token = getToken();
			const res = await fetch(`${API_BASE}/tenant/orders/${orderId}/status`, {
				method: "PATCH",
				headers: {
					Accept: "application/json",
					"Content-Type": "application/json",
					Authorization: `Bearer ${token}`,
				},
				body: JSON.stringify({ status }), // process / done / cancelled
			});

			const data = await res.json().catch(() => ({}));
			if (!res.ok) throw new Error(data?.message || "Gagal update status");
			return data;
		}

		function replaceOrder(updatedRaw) {
			const updated = normalizeOrder(updatedRaw);
			const idx = orders.findIndex((x) => x.id === updated.id);
			if (idx >= 0) orders[idx] = updated;
			else orders.unshift(updated);

			// sync selected
			if (selectedOrder && selectedOrder.id === updated.id) {
				selectedOrder = updated;
			}
			$update();
		}

		async function approvePayment() {
			try {
				$f7.dialog.preloader("Memproses...");
				const res = await patchTenantPayment(selectedOrder.id, "approve");
				$f7.dialog.close();

				// backend balikin { order: ... } atau { order: fresh }
				const updatedRaw = res.order || res;
				replaceOrder(updatedRaw);

				$f7.toast
					.create({ text: "Pembayaran disetujui ✅", closeTimeout: 1600 })
					.open();
			} catch (err) {
				$f7.dialog.close();
				$f7.dialog.alert(String(err.message || err), "Error");
			}
		}

		async function rejectPayment() {
			try {
				$f7.dialog.confirm(
					"Yakin tolak pembayaran ini?",
					"Konfirmasi",
					async () => {
						try {
							$f7.dialog.preloader("Memproses...");
							const res = await patchTenantPayment(selectedOrder.id, "reject");
							$f7.dialog.close();

							const updatedRaw = res.order || res;
							replaceOrder(updatedRaw);

							$f7.toast
								.create({ text: "Pembayaran ditolak ❌", closeTimeout: 1600 })
								.open();
						} catch (err) {
							$f7.dialog.close();
							$f7.dialog.alert(String(err.message || err), "Error");
						}
					}
				);
			} catch {}
		}

		async function updateStatus(newStatus) {
			try {
				// guard: jangan bisa process kalau belum paid
				if (
					newStatus === "process" &&
					selectedOrder.payment_status !== "paid"
				) {
					$f7.dialog.alert(
						"Pembayaran belum disetujui (paid).",
						"Tidak bisa diproses"
					);
					return;
				}

				$f7.dialog.preloader("Memproses...");
				const res = await patchTenantStatus(selectedOrder.id, newStatus);
				$f7.dialog.close();

				const updatedRaw = res.order || res;
				replaceOrder(updatedRaw);

				if (newStatus === "process") activeFilter = "process";
				if (newStatus === "done") activeFilter = "done";

				$f7.toast
					.create({ text: "Status diupdate ✅", closeTimeout: 1400 })
					.open();
			} catch (err) {
				$f7.dialog.close();
				$f7.dialog.alert(String(err.message || err), "Error");
			}
		}

		function proofUrl(path) {
			if (!path) return "";
			if (String(path).startsWith("http")) return path;
			return STORAGE_BASE + path;
		}

		function openProof() {
			// hanya untuk QRIS + ada proof
			if (!selectedOrder?.payment_proof) {
				$f7.dialog.alert("Bukti pembayaran tidak ditemukan.");
				return;
			}
			const img = document.getElementById("proofImg");
			if (img) img.src = proofUrl(selectedOrder.payment_proof);
			$f7.popup.open(".popup-proof");
		}

		// approve = set paid + status process (sedang diproses)
		async function approveAndProcess() {
			try {
				$f7.dialog.confirm(
					"Approve pembayaran dan mulai proses pesanan?",
					"Konfirmasi",
					async () => {
						try {
							$f7.dialog.preloader("Memproses...");

							// 1) approve payment -> paid
							const payRes = await patchTenantPayment(
								selectedOrder.id,
								"approve"
							);
							const payOrder = payRes.order || payRes;

							// sync lokal dulu
							replaceOrder(payOrder);

							// 2) langsung ubah status jadi process
							const stRes = await patchTenantStatus(
								selectedOrder.id,
								"process"
							);
							const stOrder = stRes.order || stRes;

							replaceOrder(stOrder);

							$f7.dialog.close();
							$f7.toast
								.create({
									text: "Approved! Pesanan masuk proses ✅",
									closeTimeout: 1800,
								})
								.open();
						} catch (err) {
							$f7.dialog.close();
							$f7.dialog.alert(String(err.message || err), "Error");
						}
					}
				);
			} catch (err) {
				$f7.dialog.alert(String(err.message || err), "Error");
			}
		}

		// badge count order status new
		function newCount() {
			return orders.filter((o) => o.status === "new").length;
		}

		// ===== lifecycle =====
		$on("pageInit", async () => {
			// bind search input (pakai DOM biasa karena form kamu plain)
			const input = document.querySelector('input[type="search"]');
			if (input) {
				input.addEventListener("input", (e) => {
					searchQuery = e.target.value || "";
					$update();
				});
			}

			await loadOrders();
		});

		// expose functions
		return $render;
	};
</script>
