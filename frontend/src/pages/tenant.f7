		font-weight: 700;
		font-size: 15px;
		color: #1a1a1a;
	}
	.food-subtitle {
		font-size: 12px;
		color: #8e8e93;
		margin-bottom: 4px;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		max-width: 200px;
	}
	.rating-pill {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		background: #4caf50;
		padding: 2px 8px;
		border-radius: 4px;
		font-size: 10px;
		color: white;
		font-weight: 600;
	}
	.card-footer-custom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		border-top: 1px dashed #eee;
		padding-top: 10px;
	}
	.price {
		font-weight: 800;
		font-size: 16px;
		color: #333;
	}

	.sheet-actions {
		display: flex;
		gap: 10px;
		align-items: center;
	}
	.sheet-actions-right {
		display: flex;
		gap: 10px;
		flex: 1;
		justify-content: flex-end;
		flex-wrap: wrap;
	}
	.sheet-actions .button {
		border-radius: 14px;
		height: 48px;
		font-weight: 700;
