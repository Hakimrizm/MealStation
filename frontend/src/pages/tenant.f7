                                                    // Jika Array: opt adalah isi data. Jika Object: opt adalah [key, value]
                                                    const label = Array.isArray(item.options) ? (opt.group || 'Opsi') : opt[0];
                                                    const value = Array.isArray(item.options) ? (opt.label || opt.value) : opt[1];
                                                    
