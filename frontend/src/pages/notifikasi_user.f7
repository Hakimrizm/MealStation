</template>

<script>
export default (props, { $, $f7, $f7router, $on }) => {
  $on('pageInit', () => {
    // Pop-up sesuai gambar referensi lo
    $f7.notification.create({
      icon: '<i class="f7-icons" style="color: #ff9500">timer</i>',
      title: 'Pemberitahuan Sistem!',
      text: 'Pesanan Ayam Geprek Anda sedang diproses! Harap tunggu sebentar.',
      closeTimeout: 3000,
    }).open();
  });

  const goBack = () => $f7router.back();
  const clearAll = () => {
    $f7.dialog.confirm('Hapus semua?', () => { $('#list-notif-user').empty(); });
  };

  return $render;
}
</script>

