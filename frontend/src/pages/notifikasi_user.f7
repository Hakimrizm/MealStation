<template>
  <div class="page" data-name="notifikasi">
    <div class="navbar navbar-blue">
      <div class="navbar-inner sliding">
        <div class="left">
          <a class="link icon-only" @click=${goBack} style="color: white;">
            <i class="icon icon-back"></i>
          </a>
        </div>
        <div class="title">Notifikasi</div>
        <div class="right">
          <a href="#" class="link icon-only" @click=${clearAll} style="color: white;">
            <i class="icon f7-icons">trash</i>
          </a>
        </div>
      </div>
    </div>

    <div class="page-content page-bg">
      <div class="list media-list no-chevron no-hairlines" style="margin-top: 0;">
        <ul id="list-notif-user">
          <li class="swipeout">
            <div class="swipeout-content">
              <a href="/riwayat-transaksi" class="item-link item-content notif-item unread">
                <div class="item-media">
                  <div class="notif-icon orange">
                    <i class="f7-icons">timer</i>
                  </div>
                </div>
                <div class="item-inner">
                  <div class="item-title-row">
                    <div class="item-title title-unread">Pesanan Diproses</div>
                    <div class="item-after time-text">Baru saja</div>
                  </div>
                  <div class="item-text">Menu <b>Ayam Geprek</b> sedang disiapkan oleh Kantin.</div>
                </div>
              </a>
            </div>
            <div class="swipeout-actions-right">
              <a href="#" class="swipeout-delete">Hapus</a>
            </div>
          </li>

          <li class="swipeout">
            <div class="swipeout-content">
              <a href="/riwayat-transaksi" class="item-link item-content notif-item read">
                <div class="item-media">
                  <div class="notif-icon green">
                    <i class="f7-icons">check_mark_circled</i>
                  </div>
                </div>
                <div class="item-inner">
                  <div class="item-title-row">
                    <div class="item-title title-read">Pesanan Selesai</div>
                    <div class="item-after time-text">10:30</div>
                  </div>
